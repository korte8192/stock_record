<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="16dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/image"
        android:src="@drawable/maintab"
        android:contentDescription="ギデオン"
        android:scaleType="centerInside"
        android:layout_marginTop="24dp"
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:id="@+id/record2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="35dp"
        android:text="◆ 記録"
        app:layout_constraintTop_toBottomOf="@id/image"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/stock_name_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20dp"
        android:text="株名 :"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/record2"
        android:layout_marginTop="5dp" />

    <EditText
        android:id="@+id/stock_name_buy"
        android:layout_height="wrap_content"
        android:layout_width="0dp"
        app:layout_constraintTop_toBottomOf="@id/record2"
        app:layout_constraintStart_toEndOf="@id/stock_name_text"
        android:hint="put in your stock name"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"/>
    <TextView
        android:id="@+id/stock_price_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20dp"
        android:text="値段 :"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stock_name_text"
        android:layout_marginTop="15dp" />

    <EditText
        android:id="@+id/stock_price_buy"
        android:layout_height="wrap_content"
        android:layout_width="0dp"
        app:layout_constraintTop_toBottomOf="@id/stock_name_text"
        app:layout_constraintStart_toEndOf="@id/stock_price_text"
        android:hint="put in your stock price"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:inputType="number"
        android:singleLine="true"/>
    <Button
        android:id="@+id/buy_botton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="購入"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/stock_price_buy"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp" />

    <ImageButton
        android:id="@+id/sell_icon"
        android:src="@drawable/sell_title"
        android:layout_width="wrap_content"
        android:layout_height="90dp"
        android:background="@null"
        android:scaleType="centerInside"
        android:contentDescription="売るページへの移行"
        app:layout_constraintTop_toBottomOf="@id/buy_botton"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>